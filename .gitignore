# Server runtime — entire data/ is instance state, regenerated by the container
server/data/

# Mod jars are packwiz-managed (tracked via mods/*.pw.toml at repo root); never committed
server/content/mods/*.jar

# Runtime caches that mods create under config/
server/content/config/spark/tmp-client/
server/content/config/waila/

# Orchestration secrets and backups
server/rcon-password.txt
server/backups/
server/.env

# Build artifacts (export.sh writes here)
build/

# Generated config snapshot (source of truth is server/content/config/)
/config/

# Generated kubejs snapshot (source of truth is server/content/kubejs/)
/kubejs/

# Client-only CurseForge jars — download manually, not tracked in git
client/mods/*.jar

# Shader packs — large binaries, not tracked in git
shaderpacks/

Speech.txt
